<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Azkiya Property</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:Poppins,sans-serif}

body{
background:#0b1120;
color:#fff;
overflow-x:hidden;
}

/* 3D canvas */
#bg{
position:fixed;
top:0;
left:0;
z-index:-1;
}

/* hero */
.hero{
height:100vh;
display:flex;
align-items:center;
justify-content:center;
text-align:center;
}

.hero h1{
font-size:3rem;
background:linear-gradient(45deg,#d4af37,#fff);
-webkit-background-clip:text;
-webkit-text-fill-color:transparent;
}

.hero p{
margin:15px 0;
opacity:0.8;
}

.btn{
padding:15px 30px;
background:#d4af37;
color:#000;
border-radius:30px;
text-decoration:none;
font-weight:600;
display:inline-block;
transition:0.3s;
}

.btn:hover{transform:scale(1.1)}

/* floating WA */
.wa-float{
position:fixed;
bottom:20px;
right:20px;
background:#25D366;
color:#fff;
padding:15px 20px;
border-radius:50px;
text-decoration:none;
font-weight:600;
box-shadow:0 10px 30px rgba(0,0,0,0.3);
}

/* grid */
.grid{
display:flex;
flex-wrap:wrap;
justify-content:center;
padding:50px 20px;
}

.card{
width:280px;
margin:15px;
padding:20px;
border-radius:20px;
background:rgba(255,255,255,0.05);
backdrop-filter:blur(10px);
transition:0.3s;
opacity:0;
transform:translateY(50px);
}

.card.show{
opacity:1;
transform:translateY(0);
}

.card:hover{
transform:translateY(-10px) scale(1.05);
}

/* form */
.form{
max-width:400px;
margin:50px auto;
padding:20px;
background:rgba(255,255,255,0.05);
border-radius:20px;
}

.form input,.form textarea{
width:100%;
margin:10px 0;
padding:10px;
border:none;
border-radius:10px;
}
</style>
</head>

<body>

<canvas id="bg"></canvas>

<section class="hero">
<div>
<h1>Azkiya Property</h1>
<p>Unit terbatas. Harga bisa naik kapan saja.</p>
<a href="https://wa.me/62881023774741" class="btn">Chat Sekarang</a>
</div>
</section>

<section class="grid">
<div class="card">Rumah Modern Rp 2,5 M</div>
<div class="card">Villa Pantai Rp 4,8 M</div>
<div class="card">Apartemen Rp 3,2 M</div>
</section>

<section class="form">
<h2>Dapatkan Properti Hari Ini</h2>
<form id="form">
<input type="text" placeholder="Nama" required>
<input type="tel" placeholder="WhatsApp" required>
<input type="text" placeholder="Budget" required>
<textarea placeholder="Kebutuhan"></textarea>
<button class="btn">Kirim</button>
</form>
</section>

<a href="https://wa.me/62881023774741" class="wa-float">WA</a>

<script>
/* 3D rumah sederhana */
const scene=new THREE.Scene();
const camera=new THREE.PerspectiveCamera(75,window.innerWidth/window.innerHeight,0.1,1000);
const renderer=new THREE.WebGLRenderer({canvas:document.getElementById('bg')});
renderer.setSize(window.innerWidth,window.innerHeight);

/* rumah */
const base=new THREE.Mesh(
new THREE.BoxGeometry(1.5,1,1.5),
new THREE.MeshStandardMaterial({color:0x888888})
);

const roof=new THREE.Mesh(
new THREE.ConeGeometry(1.2,1,4),
new THREE.MeshStandardMaterial({color:0xd4af37})
);

roof.position.y=1;

scene.add(base);
scene.add(roof);

const light=new THREE.PointLight(0xffffff,1);
light.position.set(5,5,5);
scene.add(light);

camera.position.z=4;

function animate(){
requestAnimationFrame(animate);
base.rotation.y+=0.005;
roof.rotation.y+=0.005;
renderer.render(scene,camera);
}
animate();

/* scroll animasi */
const cards=document.querySelectorAll(".card");
window.addEventListener("scroll",()=>{
cards.forEach(card=>{
let pos=card.getBoundingClientRect().top;
if(pos<window.innerHeight-100){
card.classList.add("show");
}
});
});

/* form ke WA */
document.getElementById("form").addEventListener("submit",function(e){
e.preventDefault();
let nama=document.querySelectorAll("input")[0].value;
let wa=document.querySelectorAll("input")[1].value;
let budget=document.querySelectorAll("input")[2].value;

let text=`Halo saya ${nama}. Budget ${budget}. Nomor saya ${wa}`;
window.open(`https://wa.me/62881023774741?text=${encodeURIComponent(text)}`);
});
</script>

</body>
</html>
